# Compiled classes
*.class

# Build output (Eclipse)
bin/

# Deployment directory (Dynamic Web Project)
build/
tmp/

# Eclipse project files (ignore these)
.classpath
.project
.settings/

# Eclipse server (Tomcat etc.)
Servers/

# Logs
*.log

# Local scratch / throwaway scripts (may contain hardcoded creds — do NOT commit)
scratch/

# OS files
.DS_Store
Thumbs.db

# Libraries (container provided — Tomcat runtime JARs excluded)
# But WEB-INF/lib JARs ARE part of this project (non-Maven, no package manager)
!src/main/webapp/WEB-INF/lib/*.jar